modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "static"
publicDir = "dist/public"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 20085
externalPort = 3002

[[ports]]
localPort = 25074
externalPort = 3003

[[ports]]
localPort = 26131
externalPort = 3000

[nix]
channel = "stable-25_05"
